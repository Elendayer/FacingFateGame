###############################################################################
# Unity / Git .gitignore (Unity 2021+ / Unity 6 geeignet)
# Fokus: Keine generierten Dateien in Git, aber alle relevanten Assets inkl. .meta
###############################################################################

###############################################################################
# Unity generierte Ordner (NIE versionieren)
###############################################################################
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Ll]ogs/
[Bb]uild/
[Bb]uilds/
[Mm]emoryCaptures/
[Rr]ecordings/
[Uu]ser[Ss]ettings/

# Optional: falls bei euch vorhanden
[Dd]erivedDataCache/

###############################################################################
# IDE / Editor / OS
###############################################################################
.vs/
.idea/
.vscode/
.consulo/
.gradle/
.DS_Store
Thumbs.db
Desktop.ini

###############################################################################
# Autogenerierte Projektdateien (Visual Studio / Rider / etc.)
###############################################################################
ExportedObj/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.log


###############################################################################
# Unity Crash / Debug
###############################################################################
sysinfo.txt
crashlytics-build.properties

###############################################################################
# Unity Meta-Dateien
# Meta-Dateien in Assets sollen IMMER versioniert werden (Team-Sync!)
###############################################################################
!/[Aa]ssets/**/*.meta

# Unity generierte meta-Dateien für Debug-Binaries (können ignoriert werden)
*.pidb.meta
*.pdb.meta
*.mdb.meta

###############################################################################
# Unity Asset Store Tools (optional)
###############################################################################
# /[Aa]ssets/AssetStoreTools*

###############################################################################
# TextMesh Pro (optional, nur wenn ihr es bewusst NICHT mit versionieren wollt)
###############################################################################
# [Aa]ssets/TextMesh*Pro/

###############################################################################
# JetBrains Rider Unity Plugin (wird von Rider erzeugt)
###############################################################################
[Aa]ssets/Plugins/Editor/JetBrains*

###############################################################################
# Android/Gradle/Build Outputs
###############################################################################
*.apk
*.aab

###############################################################################
# WICHTIG: Unity Exportpakete sind nur Import/Export-Archive und erzeugen Git-Lärm
# -> genau dein Problem mit *.unitypackage.meta
###############################################################################
*.unitypackage
*.unitypackage.meta

Assets/TextMesh Pro/
Assets/TextMesh Pro Examples & Extras/

# Speziell: "Third Party Support" unitypackages (z.B. Pixel Crushers)
[Aa]ssets/**/Third Party Support/*.unitypackage*
UserSettings/

###############################################################################
# Claude Code
###############################################################################
.claude/worktrees/

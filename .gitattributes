# Unity YAML text files — force LF on all machines
*.asset     text eol=lf
*.unity     text eol=lf
*.prefab    text eol=lf
*.mat       text eol=lf
*.meta      text eol=lf
*.controller text eol=lf
*.anim      text eol=lf
*.playable  text eol=lf
*.overrideController text eol=lf
*.shadervariants text eol=lf
*.spriteatlas text eol=lf
*.asmdef    text eol=lf
*.asmref    text eol=lf
*.shader    text eol=lf
*.hlsl      text eol=lf
*.cginc     text eol=lf
*.cs        text eol=lf

# Binary — never touch line endings
*.png       binary
*.jpg       binary
*.jpeg      binary
*.tga       binary
*.tiff      binary
*.psd       binary
*.gif       binary
*.bmp       binary
*.exr       binary
*.hdr       binary
*.pdf       binary
*.zip       binary
*.7z        binary
*.dll       binary
*.so        binary
*.dylib     binary
*.wav       binary
*.mp3       binary
*.ogg       binary
*.aiff      binary
*.fbx       binary
*.obj       binary
*.blend     binary
*.ttf       binary
*.otf       binary
*.cubemap   binary
*.unitypackage binary

  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Tutorial_de
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: de
  m_SharedData: {fileID: 11400000, guid: 81577f562cf5c1f4a92e57e7d8b77d62, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 8310534144
    m_Localized: "Willkommen bei Facing Fate! Dieses Tutorial f\xFChrt dich durch
      die Grundlagen des Kampfes. \nKlicke auf \u201EWeiter\"."
    m_Metadata:
      m_Items: []
  - m_Id: 53353164800
    m_Localized: "Links siehst du deine Lebenspunkte (HP) und Ausdauer (SP).\nStamina
      bestimmt, wie viele und wie teure Karten du pro Zug spielen kannst.\nAu\xDFerdem
      beeinflusst sie, wie weit du dich \xFCber das Spielfeld bewegen kannst."
    m_Metadata:
      m_Items: []
  - m_Id: 56008159232
    m_Localized: "Das ist deine Hand. Jede Karte zeigt ihre Stamina-Kosten oben links.\nBewege
      den Mauszeiger \xFCber eine Karte, um Details, Reichweite und Effekte zu sehen."
    m_Metadata:
      m_Items: []
  - m_Id: 57769766912
    m_Localized: "Bewege den Mauszeiger \xFCber einen Gegner, um seine Werte zu sehen.
      \nKlicke auf den Gegner, um die Ansicht zu fixieren."
    m_Metadata:
      m_Items: []
  - m_Id: 59422322688
    m_Localized: "Spiel jetzt die Angriffskarte! Ziehe sie auf den Gegner. \nBeachte:
      Karten haben eine Reichweite. Ist man zu weit weg verfehlt der Angriff."
    m_Metadata:
      m_Items: []
  - m_Id: 61104238592
    m_Localized: "Du kannst Stamina auch verwenden, um dich \xFCber die Karte zu
      bewegen. \nKlicke und ziehe an die Stelle, zu der du dich bewegen m\xF6chtest.\nDeine
      Position beeinflusst, was du sehen kannst und was du mit deinen Karten erreichen
      kannst."
    m_Metadata:
      m_Items: []
  - m_Id: 62958120960
    m_Localized: "Spiele Heavens Spear! Diese Karte muss mehrere Gegner anvisieren.
      \nKlicke auf drei Gegner in Reichweite, um sie zu spielen."
    m_Metadata:
      m_Items: []
  - m_Id: 64614871040
    m_Localized: "Dein Zug ist vorbei. Dr\xFCcke \u201EZug beenden\u201C! \nDanach
      ist der Gegner an der Reihe."
    m_Metadata:
      m_Items: []
  - m_Id: 66380673024
    m_Localized: "Der Gegner hat seinen Zug beendet. Du hast neue Karten gezogen
      und deine Stamina ist aufgefrischt.\nJede Runde bietet neue M\xF6glichkeiten,
      also kombiniere deine Karten klug!"
    m_Metadata:
      m_Items: []
  - m_Id: 68385550336
    m_Localized: "Besiege den Gegner! Alle Karten sind spielbar. \nAchte auf Reichweite,
      Stamina-Kosten und Statuseffekte. Viel Erfolg!"
    m_Metadata:
      m_Items: []
  - m_Id: 14214657257472
    m_Localized: 'Gut gemacht! Der Gegner hat Schaden erlitten, dadurch haben sich
      seine HP verringert.

      Sind alle Gegner besiegt, endet der Kampf.'
    m_Metadata:
      m_Items: []
  - m_Id: 17840951832576
    m_Localized: "Statuseffekte wie Blutung wirken \xFCber mehrere Runden und werden
      als Symbole unter der HP-Leiste angezeigt.\nBewege den Mauszeiger \xFCber ein
      Symbol, um den Effekt zu sehen."
    m_Metadata:
      m_Items: []
  - m_Id: 16562616053760
    m_Localized: Du hast noch weitere Karten auf der Hand, aber keine Stamina mehr,
      um sie zu spielen.
    m_Metadata:
      m_Items: []
  - m_Id: 1120323220582400
    m_Localized: "Du hast das Tutorial abgeschlossen! \nDu kannst andere Szenarien
      im Hauptmen\xFC ausw\xE4hlen."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
